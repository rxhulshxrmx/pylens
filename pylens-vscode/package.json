{
  "name": "pylens",
  "displayName": "PyLens",
  "description": "Provenance tracking for LLM-generated code — trace any function back to its requirement, AI session, and commit.",
  "version": "0.1.0",
  "publisher": "pylens",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other", "SCM Providers"],
  "keywords": ["provenance", "ai", "llm", "git", "blame", "tracing"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pylens.showProvenance",
        "title": "Show Provenance",
        "category": "PyLens",
        "icon": "$(git-commit)"
      },
      {
        "command": "pylens.toggleAnnotations",
        "title": "Toggle Annotations",
        "category": "PyLens",
        "icon": "$(eye)"
      },
      {
        "command": "pylens.openPanel",
        "title": "Open Panel",
        "category": "PyLens",
        "icon": "$(graph)"
      },
      {
        "command": "pylens.showWelcome",
        "title": "Show Welcome",
        "category": "PyLens"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "pylensPanel",
          "title": "PyLens",
          "icon": "$(git-commit)"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "pylens.sidebar",
          "name": "PyLens Provenance"
        }
      ],
      "pylensPanel": [
        {
          "type": "webview",
          "id": "pylens.panel",
          "name": "PyLens"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "pylens.showProvenance",
          "group": "navigation@1",
          "when": "editorTextFocus"
        }
      ],
      "editor/title": [
        {
          "command": "pylens.toggleAnnotations",
          "group": "navigation@1",
          "when": "editorTextFocus"
        },
        {
          "command": "pylens.openPanel",
          "group": "navigation@2",
          "when": "editorTextFocus"
        }
      ]
    },
    "configuration": {
      "title": "PyLens",
      "properties": {
        "pylens.enableAnnotations": {
          "type": "boolean",
          "default": true,
          "description": "Show PyLens inline annotations and gutter icons."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
